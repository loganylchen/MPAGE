{
  "name": "MPAGE R Development Environment",
  "image": "btrspg/env-mpage:20250825",
  "features": {},
  "mounts": [
    "source=${localWorkspaceFolder}/,target=/home/vscode/workspace/,type=bind,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot-chat",
        "GitHub.copilot",
        "Anthropic.claude-code",
        "ivanhofer.git-assistant",
        "mhutchie.git-graph",
        "github.vscode-github-actions",
        "eamodio.gitlens",
        "ms-toolsai.jupyter",
        "mathematic.vscode-latex",
        "REditorSupport.r",
        "redhat.vscode-yaml",
        "ms-python.python",
        "ms-toolsai.vscode-jupyter-powertoys",
        "RDebugger.r-debugger"
      ]
    }
  },
  "remoteUser": "logan"
}